        "mode": "html",
        "content": "<div style=\"font-family:Inter,Helvetica,Arial,sans-serif;max-width:960px;margin:0 auto;padding:24px;color:#d8d9da\">\n  <div style=\"text-align:center;margin-bottom:40px\">\n    <p style=\"font-family:'Courier New',Courier,monospace;font-size:3.2rem;font-weight:700;color:#ff9830;margin-bottom:12px;text-shadow:3px 3px 0px #e0544e,6px 6px 0px #3d71d933;letter-spacing:0.12em;text-transform:uppercase\">Code To Cloud</p>\n    <h1 style=\"font-size:1.6rem;font-weight:700;margin-bottom:8px;color:#8e8e8e\">Observability Workshop</h1>\n  </div>\n\n  <div style=\"margin-bottom:32px\">\n    <h2 style=\"font-size:1.2rem;font-weight:600;margin-bottom:16px;color:#ff9830;border-bottom:1px solid #2c3235;padding-bottom:8px\">Architecture</h2>\n    <div style=\"display:flex;flex-direction:column;align-items:center;gap:8px;padding:24px;background:#1a1b1f;border-radius:8px;border:1px solid #2c3235\">\n      <!-- Traefik -->\n      <div style=\"display:flex;gap:16px;align-items:center\">\n        <div style=\"padding:12px 20px;border-radius:6px;font-weight:600;font-size:0.85rem;text-align:center;min-width:160px;background:#4a4a4a;color:white\">Traefik<br/><small>Reverse Proxy</small></div>\n      </div>\n      <div style=\"display:flex;gap:16px;align-items:center\">\n        <span style=\"color:#6e6e6e;font-size:1.4rem\">&darr;</span>\n      </div>\n      <!-- Services -->\n      <div style=\"display:flex;gap:16px;align-items:center\">\n        <div style=\"padding:12px 20px;border-radius:6px;font-weight:600;font-size:0.85rem;text-align:center;min-width:160px;background:#3d71d9;color:white\">Service A<br/><small>Gateway</small></div>\n      </div>\n      <div style=\"display:flex;gap:16px;align-items:center\">\n        <span style=\"color:#6e6e6e;font-size:1.4rem\">&darr;</span>\n        <span style=\"width:80px\"></span>\n        <span style=\"color:#6e6e6e;font-size:1.4rem\">&darr;</span>\n      </div>\n      <div style=\"display:flex;gap:16px;align-items:flex-start\">\n        <div style=\"display:flex;flex-direction:column;align-items:center;gap:8px\">\n          <div style=\"padding:12px 20px;border-radius:6px;font-weight:600;font-size:0.85rem;text-align:center;min-width:160px;background:#56a64b;color:white\">Service B<br/><small>Orders</small></div>\n          <span style=\"color:#6e6e6e;font-size:1.4rem\">&darr;</span>\n          <div style=\"padding:12px 20px;border-radius:6px;font-weight:600;font-size:0.85rem;text-align:center;min-width:160px;background:#8a56d9;color:white\">Service C<br/><small>Products</small></div>\n        </div>\n        <div style=\"padding:12px 20px;border-radius:6px;font-weight:600;font-size:0.85rem;text-align:center;min-width:160px;background:#e0544e;color:white\">Service D<br/><small>Analytics</small></div>\n      </div>\n      <!-- Shared infrastructure -->\n      <div style=\"display:flex;gap:16px;align-items:center;margin-top:12px\">\n        <span style=\"color:#6e6e6e;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.1em\">shared infrastructure</span>\n      </div>\n      <div style=\"display:flex;gap:16px;align-items:center;padding:16px;background:#12131566;border-radius:6px;border:1px dashed #2c3235\">\n        <div style=\"padding:12px 20px;border-radius:6px;font-weight:600;font-size:0.85rem;text-align:center;min-width:140px;background:#336791;color:white\">PostgreSQL<br/><small>B, C, D</small></div>\n        <div style=\"padding:12px 20px;border-radius:6px;font-weight:600;font-size:0.85rem;text-align:center;min-width:140px;background:#dc382c;color:white\">Redis<br/><small>A, B</small></div>\n      </div>\n    </div>\n  </div>\n\n  <div style=\"margin-bottom:32px\">\n    <h2 style=\"font-size:1.2rem;font-weight:600;margin-bottom:16px;color:#ff9830;border-bottom:1px solid #2c3235;padding-bottom:8px\">Your Toolkit</h2>\n    <div style=\"display:grid;grid-template-columns:repeat(4,1fr);gap:12px\">\n      <div style=\"background:#1a1b1f;border:1px solid #2c3235;border-radius:8px;padding:16px\">\n        <h3 style=\"font-size:0.95rem;font-weight:600;margin:0 0 4px 0;color:#eee\">Prometheus</h3>\n        <p style=\"font-size:0.82rem;color:#8e8e8e;margin:0\">Metrics &mdash; rates, errors, latency</p>\n      </div>\n      <div style=\"background:#1a1b1f;border:1px solid #2c3235;border-radius:8px;padding:16px\">\n        <h3 style=\"font-size:0.95rem;font-weight:600;margin:0 0 4px 0;color:#eee\">Tempo</h3>\n        <p style=\"font-size:0.82rem;color:#8e8e8e;margin:0\">Distributed tracing &mdash; request waterfalls</p>\n      </div>\n      <div style=\"background:#1a1b1f;border:1px solid #2c3235;border-radius:8px;padding:16px\">\n        <h3 style=\"font-size:0.95rem;font-weight:600;margin:0 0 4px 0;color:#eee\">Loki</h3>\n        <p style=\"font-size:0.82rem;color:#8e8e8e;margin:0\">Log aggregation &mdash; structured logs</p>\n      </div>\n      <div style=\"background:#1a1b1f;border:1px solid #2c3235;border-radius:8px;padding:16px\">\n        <h3 style=\"font-size:0.95rem;font-weight:600;margin:0 0 4px 0;color:#eee\">Pyroscope</h3>\n        <p style=\"font-size:0.82rem;color:#8e8e8e;margin:0\">Continuous profiling &mdash; flame graphs</p>\n      </div>\n    </div>\n  </div>\n\n  <div style=\"margin-bottom:32px\">\n    <h2 style=\"font-size:1.2rem;font-weight:600;margin-bottom:16px;color:#ff9830;border-bottom:1px solid #2c3235;padding-bottom:8px\">Dashboards</h2>\n    <table style=\"width:100%;border-collapse:collapse\">\n      <thead>\n        <tr>\n          <th style=\"text-align:left;padding:8px 12px;font-size:0.8rem;color:#8e8e8e;border-bottom:1px solid #2c3235;text-transform:uppercase;letter-spacing:0.05em\">#</th>\n          <th style=\"text-align:left;padding:8px 12px;font-size:0.8rem;color:#8e8e8e;border-bottom:1px solid #2c3235;text-transform:uppercase;letter-spacing:0.05em\">Dashboard</th>\n          <th style=\"text-align:left;padding:8px 12px;font-size:0.8rem;color:#8e8e8e;border-bottom:1px solid #2c3235;text-transform:uppercase;letter-spacing:0.05em\">Signal</th>\n          <th style=\"text-align:left;padding:8px 12px;font-size:0.8rem;color:#8e8e8e;border-bottom:1px solid #2c3235;text-transform:uppercase;letter-spacing:0.05em\">What to look for</th>\n        </tr>\n      </thead>\n      <tbody>\n        <tr>\n          <td style=\"padding:10px 12px;font-size:0.9rem;border-bottom:1px solid #1e2124\">1</td>\n          <td style=\"padding:10px 12px;font-size:0.9rem;border-bottom:1px solid #1e2124\">Service Overview</td>\n          <td style=\"padding:10px 12px;font-size:0.9rem;border-bottom:1px solid #1e2124\"><span style=\"display:inline-block;padding:2px 8px;border-radius:4px;font-size:0.75rem;font-weight:600;background:#3d71d933;color:#6fa2ff\">Metrics</span></td>\n          <td style=\"padding:10px 12px;font-size:0.9rem;border-bottom:1px solid #1e2124\">High-level health of all services</td>\n        </tr>\n        <tr>\n          <td style=\"padding:10px 12px;font-size:0.9rem;border-bottom:1px solid #1e2124\">2</td>\n          <td style=\"padding:10px 12px;font-size:0.9rem;border-bottom:1px solid #1e2124\">Cache Behavior</td>\n          <td style=\"padding:10px 12px;font-size:0.9rem;border-bottom:1px solid #1e2124\"><span style=\"display:inline-block;padding:2px 8px;border-radius:4px;font-size:0.75rem;font-weight:600;background:#3d71d933;color:#6fa2ff\">Metrics</span> <span style=\"display:inline-block;padding:2px 8px;border-radius:4px;font-size:0.75rem;font-weight:600;background:#56a64b33;color:#73bf69\">Traces</span></td>\n          <td style=\"padding:10px 12px;font-size:0.9rem;border-bottom:1px solid #1e2124\">Cache hit ratio &amp; thundering herd</td>\n        </tr>\n        <tr>\n          <td style=\"padding:10px 12px;font-size:0.9rem;border-bottom:1px solid #1e2124\">3</td>\n          <td style=\"padding:10px 12px;font-size:0.9rem;border-bottom:1px solid #1e2124\">Service Dependencies</td>\n          <td style=\"padding:10px 12px;font-size:0.9rem;border-bottom:1px solid #1e2124\"><span style=\"display:inline-block;padding:2px 8px;border-radius:4px;font-size:0.75rem;font-weight:600;background:#56a64b33;color:#73bf69\">Traces</span></td>\n          <td style=\"padding:10px 12px;font-size:0.9rem;border-bottom:1px solid #1e2124\">N+1 query patterns</td>\n        </tr>\n        <tr>\n          <td style=\"padding:10px 12px;font-size:0.9rem;border-bottom:1px solid #1e2124\">4</td>\n          <td style=\"padding:10px 12px;font-size:0.9rem;border-bottom:1px solid #1e2124\">Database Connections</td>\n          <td style=\"padding:10px 12px;font-size:0.9rem;border-bottom:1px solid #1e2124\"><span style=\"display:inline-block;padding:2px 8px;border-radius:4px;font-size:0.75rem;font-weight:600;background:#3d71d933;color:#6fa2ff\">Metrics</span> <span style=\"display:inline-block;padding:2px 8px;border-radius:4px;font-size:0.75rem;font-weight:600;background:#e0544e33;color:#ff6b6b\">Logs</span></td>\n          <td style=\"padding:10px 12px;font-size:0.9rem;border-bottom:1px solid #1e2124\">Pool exhaustion under load</td>\n        </tr>\n        <tr>\n          <td style=\"padding:10px 12px;font-size:0.9rem\">5</td>\n          <td style=\"padding:10px 12px;font-size:0.9rem\">CPU Profiling</td>\n          <td style=\"padding:10px 12px;font-size:0.9rem\"><span style=\"display:inline-block;padding:2px 8px;border-radius:4px;font-size:0.75rem;font-weight:600;background:#8a56d933;color:#b48aff\">Profiling</span></td>\n          <td style=\"padding:10px 12px;font-size:0.9rem\">Regex compilation hot spots</td>\n        </tr>\n      </tbody>\n    </table>\n  </div>\n\n  <div style=\"margin-bottom:32px\">\n    <h2 style=\"font-size:1.2rem;font-weight:600;margin-bottom:16px;color:#ff9830;border-bottom:1px solid #2c3235;padding-bottom:8px\">Quick Start</h2>\n    <div style=\"background:#1a1b1f;border:1px solid #2c3235;border-radius:8px;padding:16px 20px;font-family:monospace;font-size:0.85rem;color:#73bf69\">$ oha -z 3m -c 50 -q 150 http://localhost/api/summary</div