  ],
  "timezone": "browser",
  "schemaVersion": 16,
  "version": 0,
  "refresh": "5s",
  "panels": [
    {
      "id": 10,
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "type": "text",
      "title": "",
      "options": {
        "mode": "html",
        "content": "<div style='font-family:Inter,Helvetica,Arial,sans-serif;padding:12px 16px;color:#d8d9da;display:grid;grid-template-columns:1fr 1fr;gap:24px'><div><p style='font-size:0.75rem;font-weight:600;color:#ff9830;text-transform:uppercase;letter-spacing:0.1em;margin:0 0 8px 0'>How to Trigger</p><div style='background:#1a1b1f;border:1px solid #2c3235;border-radius:6px;padding:10px 16px;font-family:monospace;font-size:0.85rem;color:#73bf69'>$ oha -z 3m -c 50 -q 150 http://localhost/api/summary</div><p style='font-size:0.75rem;font-weight:600;color:#ff9830;text-transform:uppercase;letter-spacing:0.1em;margin:16px 0 4px 0'>Location</p><p style='font-size:0.83rem;color:#aaa;margin:0;font-family:monospace'>service-a/src/handlers.rs \u2014 get_summary()</p></div><div><p style='font-size:0.75rem;font-weight:600;color:#ff9830;text-transform:uppercase;letter-spacing:0.1em;margin:0 0 8px 0'>What's Happening</p><p style='font-size:0.83rem;color:#aaa;margin:0 0 10px 0'>Service A caches the /summary response for 30 seconds. When the TTL expires, every in-flight request simultaneously misses the cache and fans out to Service B and Service D \u2014 a thundering herd that overwhelms downstream services at once.</p><p style='font-size:0.7rem;font-weight:600;color:#8e8e8e;text-transform:uppercase;letter-spacing:0.08em;margin:0 0 4px 0'>How to identify</p><ul style='font-size:0.83rem;color:#aaa;margin:0 0 10px 0;padding-left:16px'><li>Cache hit ratio drops to 0% every 15 seconds</li><li>Traefik p99 latency spikes at the exact moment of TTL expiry</li><li>Service B and D show simultaneous request bursts every ~15 seconds</li></ul><p style='font-size:0.7rem;font-weight:600;color:#8e8e8e;text-transform:uppercase;letter-spacing:0.08em;margin:0 0 4px 0'>The Fix</p><p style='font-size:0.83rem;color:#aaa;margin:0'>Increase TTL to 5+ minutes; add a mutex-based stampede guard so only one request refreshes at a time; or use a stale-while-revalidate pattern.</p></div></div>"
      }
    },
    {
      "id": 1,
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "type": "timeseries",
      "title": "Cache Miss Rate",
      "targets": [
        {
          "expr": "rate(cache_misses_total{endpoint=\"summary\"}[30s])",
          "legendFormat": "Cache Misses",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2
          },
          "unit": "ops"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Cache Misses"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 5,
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "type": "timeseries",
      "title": "Traefik Gateway Latency",
      "description": "Latency spikes at cache expiry as thundering herd hits downstream",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(traefik_entrypoint_request_duration_seconds_bucket{entrypoint=\"web\"}[30s])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(traefik_entrypoint_request_duration_seconds_bucket{entrypoint=\"web\"}[30s])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(traefik_entrypoint_request_duration_seconds_bucket{entrypoint=\"web\"}[30s])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "p99"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 2,
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 0,
        "y": 19
      },
      "type": "stat",
      "title": "Cache Hit Ratio (1m)",
      "targets": [
        {
          "expr": "sum(rate(cache_hits_total{endpoint=\"summary\"}[1m])) / (sum(rate(cache_hits_total{endpoint=\"summary\"}[1m])) + sum(rate(cache_misses_total{endpoint=\"summary\"}[1m]))) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "red"
              },
              {
                "value": 50,
                "color": "yellow"
              },
              {
                "value": 80,
                "color": "green"
              }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 12,
        "y": 19
      },
      "type": "stat",
      "title": "Gateway 5xx Error Rate",
      "description": "HTTP 5xx responses returned to users by Traefik. Spikes during thundering herd as downstream services are overwhelmed.",
      "targets": [
        {
          "expr": "sum(rate(traefik_entrypoint_requests_total{entrypoint=\"web\",code=~\"5..\"}[1m])) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 0.01,
                "color": "red"
              }
            ]
          }
        }
      }
    },
    {
